# Optional: HTTPS URL returning JSON { "restrooms": [ { "id", "name", "latitude", "longitude", "type", ... } ] }
EXPO_PUBLIC_RESTROOM_API_URL=

# Android Google Maps (required for Maps on Android release builds)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# In-app “Privacy policy” link (Profile & Safe & inclusive)
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://www.example.com/privacy
